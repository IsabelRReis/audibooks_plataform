{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "^/api/(.*)$",
            "dest": "/api/$1"
        },
        {
            "src": "^/$",
            "dest": "/frontend/login.html"
        },
        {
            "src": "^/(.*)$",
            "dest": "/frontend/$1"
        }
    ]
}